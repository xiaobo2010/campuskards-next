# ── Database (systemd: localhost, 非 docker) ──
DB_USER=ck
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://ck:CHANGE_ME_STRONG_PASSWORD@localhost:5432/campuskards

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Auth ──
SECRET_KEY=CHANGE_ME_TO_RANDOM_HEX_32_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS — 替换为你的前端域名 ──
CORS_ORIGINS=["https://your-frontend-domain.com","http://localhost:3000"]

# ── production → Secure + SameSite=none cookies; development → lax HTTP cookies ──
ENVIRONMENT=production
